<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
      const roomId = "<%= roomId %>";
      const base = "<%= baseURL %>";
    </script>
    <title><%=roomId%> - Chatroom</title>
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    <script src="/socket.io/socket.io.js" defer></script>
    <script src="<%=baseURL%>/js/app.js" defer></script>
    <script src="<%=baseURL%>/js/chatroom.js" defer></script>
    <!-- <script src="<%=baseURL%>/script.js" defer></script> -->
    <link rel="stylesheet" href="<%=baseURL%>/css/styles.css" />
    <link rel="stylesheet" href="<%=baseURL%>/css/chatroom.css" />
  </head>

  <body class="bg-neutral-900" id="videoUI">
    <div class="flex-1 flex gap-2 py-2 px-2" id="videoZone">
      <div class="h-full relative flex-1">
        <div class="h-full w-full">
          <div id="videoGrid" class="video-grid"></div>
        </div>
      </div>
      <aside class="hidden sidepanel" id="infoPanel">
        <div class="header">
          <div>Meeting details</div>
          <button
            type="button"
            class="text-2xl leading-none h-8 w-8 rounded-full flex items-center justify-center hover:bg-slate-100 pb-1 -mr-1"
            onclick="showPanel('info')">
            &times;
          </button>
        </div>
        <div class="px-6 border-b border-gray-200 pb-6">
          <p class="text-sm text-neutral-800 font-medium mb-1">Joining Info</p>
          <input
            type="text"
            id="roomUrlInput"
            readonly
            class="text-sm text-neutral-500 w-full mb-6" />

          <button
            type="button"
            class="flex items-center gap-2 text-blue-500"
            id="copyLinkBtn">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-5 h-5">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
            </svg>
            <span class="text-sm"> Copy joining info </span>
          </button>
        </div>
        <!-- <div class="px-6 py-4 text-neutral-700">In call</div> -->
        <div class="px-6 py-4 text-neutral-700">Participants</div>
        <div class="px-6 py">
          <div
            class="border border-neutral-400 rounded-md py-2.5 px-4 flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-5 h-5 text-gray-400">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            <input
              type="text"
              autocomplete="off"
              placeholder="Search for people"
              onkeyup="searchParticipants()"
              id="searchInput"
              class="focus:outline-none placeholder:text-md placeholder:font-light placeholder:text-neutral-500 text-neutral-700" />
          </div>
        </div>
        <div class="ulist" id="participantsList"></div>
      </aside>
      <aside class="hidden sidepanel-flex" id="chatPanel">
        <div class="header">
          <div>Chat Messages</div>
          <button
            type="button"
            class="text-2xl leading-none h-8 w-8 rounded-full flex items-center justify-center hover:bg-slate-100 pb-1 -mr-1"
            onclick="showPanel('chat')">
            &times;
          </button>
        </div>
        <div class="px-6">
          <div
            class="bg-neutral-100 text-neutral-600 text-center leading-tight text-xs rounded-lg p-5 mb-4">
            Messages can only be seen by the people in the call and are deleted
            when call ends.
          </div>
        </div>
        <div class="chat-list" id="chats-container"></div>
        <div id="send-form">
          <div class="chat-input">
            <textarea
              id="message-input"
              spellcheck="false"
              rows="1"
              class="w-full pt-3.5 px-2 h-12 bg-transparent resize-none placeholder:text-neutral-500 text-sm focus:outline-none"
              placeholder="Send a message to everyone"></textarea>
            <button
              type="button"
              id="send-button"
              class="text-neutral-500 disabled:opacity-50"
              disabled>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>
          </div>
        </div>
      </aside>
    </div>
    <div
      class="h-20 px-2 sm:px-6 flex text-neutral-300 justify-between items-center"
      id="controlBar">
      <div class="hidden md:flex space-x-4">
        <div id="clock"></div>
        <div>|</div>
        <div><%=roomId%></div>
      </div>
      <div>
        <div class="flex items-center gap-1 sm:gap-4">
          <button
            type="button"
            class="control-btn__on"
            id="btnAudio"
            onclick="muteUnmute()">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5">
              <path
                d="M8.25 4.5a3.75 3.75 0 1 1 7.5 0v8.25a3.75 3.75 0 1 1-7.5 0V4.5Z" />
              <path
                d="M6 10.5a.75.75 0 0 1 .75.75v1.5a5.25 5.25 0 1 0 10.5 0v-1.5a.75.75 0 0 1 1.5 0v1.5a6.751 6.751 0 0 1-6 6.709v2.291h3a.75.75 0 0 1 0 1.5h-7.5a.75.75 0 0 1 0-1.5h3v-2.291a6.751 6.751 0 0 1-6-6.709v-1.5A.75.75 0 0 1 6 10.5Z" />
            </svg>
          </button>
          <button
            type="button"
            class="control-btn__on"
            id="btnVideo"
            onclick="cameraOnOff()">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5">
              <path
                d="M4.5 4.5a3 3 0 0 0-3 3v9a3 3 0 0 0 3 3h8.25a3 3 0 0 0 3-3v-9a3 3 0 0 0-3-3H4.5ZM19.94 18.75l-2.69-2.69V7.94l2.69-2.69c.944-.945 2.56-.276 2.56 1.06v11.38c0 1.336-1.616 2.005-2.56 1.06Z" />
            </svg>
          </button>
          <button
            type="button"
            class="control-btn__off"
            id="btnVideo"
            onclick="endCall()">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 rotate-[135deg]">
              <path
                fill-rule="evenodd"
                d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
                clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
      <div>
        <div class="flex gap-2 md:gap-4">
          <button
            type="button"
            id="chatInfoBtn"
            onclick="showPanel('info')"
            class="hover:bg-neutral-800 h-9 w-9 flex items-center justify-center rounded-full cursor-pointer transition xtrabtns">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5">
              <path
                fill-rule="evenodd"
                d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z"
                clip-rule="evenodd" />
            </svg>
          </button>
          <button
            type="button"
            id="chatBtn"
            onclick="showPanel('chat')"
            class="hover:bg-neutral-800 h-9 w-9 flex items-center justify-center rounded-full cursor-pointer transition xtrabtns">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5">
              <path
                fill-rule="evenodd"
                d="M4.848 2.771A49.144 49.144 0 0 1 12 2.25c2.43 0 4.817.178 7.152.52 1.978.292 3.348 2.024 3.348 3.97v6.02c0 1.946-1.37 3.678-3.348 3.97-1.94.284-3.916.455-5.922.505a.39.39 0 0 0-.266.112L8.78 21.53A.75.75 0 0 1 7.5 21v-3.955a48.842 48.842 0 0 1-2.652-.316c-1.978-.29-3.348-2.024-3.348-3.97V6.741c0-1.946 1.37-3.68 3.348-3.97Z"
                clip-rule="evenodd" />
            </svg>
            <!-- <span
              class="flex absolute bg-white bg-opacity-10 items-center justify-center w-5 h-5 text-[10px] font-semibold rounded-full -mt-5 -mr-8"
              id="participantsCount"
              >1</span
            > -->
          </button>
        </div>
      </div>
    </div>
    <div id="snackbar"></div>
    <div
      class="fixed inset-0 bg-black bg-opacity-70 z-10 items-center justify-center p-4 hidden"
      id="mediaAlert">
      <div class="bg-white rounded-md w-full max-w-sm" role="alertdialog">
        <h5 class="font-medium pt-5 px-6 pb-2">
          Camera and microphone are blocked
        </h5>
        <p class="text-sm text-neutral-500 px-6">
          This application requires access to your camera and microphone. Please
          allow access for these.
        </p>
        <div class="flex justify-end p-2">
          <span role="button" class="button text-primary" id="dismissBtn"
            >Dismiss</span
          >
        </div>
      </div>
    </div>
    <div
      class="fixed inset-0 bg-black z-10 items-center justify-center p-4 hidden"
      id="endAlert">
      <div class="bg-white rounded-md w-full max-w-sm" role="alertdialog">
        <h5 class="font-medium pt-5 px-6 pb-2">Meeting Ended</h5>
        <p class="text-sm text-neutral-500 px-6">
          The meeting has been ended by the host. Thank you for your
          participations.
        </p>
        <div class="flex justify-end p-2">
          <span
            role="button"
            class="button text-primary font-semibold"
            id="returnHomeBtn"
            >OK</span
          >
        </div>
      </div>
    </div>
  </body>
</html>
